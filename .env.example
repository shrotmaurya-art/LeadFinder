CITY                             # City to search leads in
CATEGORIES                       # Comma-separated list of business categories
OLLAMA_MODEL=llama3.1:8b         # Ollama model name
COOLDOWN_DAYS=15                 # Days to wait before re-contacting a lead
MAX_FOLLOW_UPS=2                 # Max follow-up messages per lead
EMAIL_DAILY_CAP=30               # Max emails to send per day
WHATSAPP_DAILY_CAP=30            # Max WhatsApp messages per day
LEAD_SCORE_THRESHOLD=40          # Minimum score to qualify a lead
APP_TIMEZONE=Asia/Kolkata        # Application timezone
DATA_SOURCE=playwright           # Data source: playwright or api
GOOGLE_PLACES_API_KEY=           # Google Places API key (optional)
INCLUDE_RATINGS_VIA_API=false    # Fetch ratings via API instead of scraping
